# Environment Configuration Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git

# MQTT Broker Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=fdm-simulator-dev
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT Topics
MQTT_TOPIC_STATE=printer/state
MQTT_TOPIC_MOVEMENT=printer/movement/position
MQTT_TOPIC_EXTRUSION=printer/movement/extrusion

# OctoPrint Integration (Optional)
OCTOPRINT_ENABLED=false
OCTOPRINT_URL=http://localhost:5000
OCTOPRINT_API_KEY=
OCTOPRINT_POLL_INTERVAL=500

# Stream Mode Settings
STREAM_MODE_ENABLED=true
STREAM_DEBOUNCE_MS=100
STREAM_AUTO_START=false
